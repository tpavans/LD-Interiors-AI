PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/ld_interiors
JWT_SECRET=supersecretjwtkeyforldinteriors123
NODE_ENV=development

# Cloudinary Configuration (Requires user credentials to function)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Account Overrides (Optional)
ADMIN1_EMAIL=admin1@ldinteriors.com
ADMIN1_PASSWORD=Admin1SecurePassword!
ADMIN2_EMAIL=admin2@ldinteriors.com
ADMIN2_PASSWORD=Admin2SecurePassword!

# Twilio Configuration for Voice Call Agent (Get these from Twilio Console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_purchased_phone_number

